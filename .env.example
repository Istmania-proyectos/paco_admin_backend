# Servidor
PORT=3045
CORS_ORIGIN=*
REQUEST_BODY_LIMIT=20mb

# SQL Server (la base original usa PACO_ADMIN_S4HANA)
DB_HOST=
DB_PORT=1433
DB_NAME=PACO_ADMIN_S4HANA
DB_USER=
DB_PASSWORD=
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_POOL_MAX=10

# Deben coincidir con JwtIssuerOptions del backend ASP.NET para compatibilidad
JWT_SECRET=
JWT_ISSUER=
JWT_AUDIENCE=
JWT_EXPIRES_IN_SECONDS=7200

# Reemplaza la clave incrustada que usaba ResetPasswordAdmin
ADMIN_RESET_SECRET=
ADMIN_INITIAL_USERNAME=manager
ADMIN_INITIAL_PASSWORD=

# SMTP usado por GET /api/Paco/Correo
EMAIL_FROM=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_TIMEOUT_MS=10000

# URL base de la pantalla de detalle. Ejemplo: https://admin.ejemplo.com/tickets
# URL pública donde Jefe de Marca/Mercadeo/Gerencia responden el correo.
# Ejemplo: https://admin.ejemplo.com/ticket/aprobar
TICKETS_APPROVAL_RESPONSE_URL=
TICKETS_APPROVAL_TOKEN_EXPIRATION_HOURS=120

# Automatizacion de tickets de CheckIn. Mientras ENABLED=false no existe
# ejecucion periodica; los endpoints de simulacion tampoco crean ni envian.
TICKETS_AUTOMATION_ENABLED=false
TICKETS_AUTOMATION_DRY_RUN=true
TICKETS_AUTOMATION_INTERVAL_MINUTES=60
TICKETS_AUTOMATION_FORM_ID=14
TICKETS_AUTOMATION_RENEWAL_DAYS=30
TICKETS_AUTOMATION_USER_ID=AUTOMATIZACION_CHECKIN

# Destinatarios estaticos pendientes de confirmar.
TICKETS_MARKETING_MANAGER_EMAIL=jairo.canales@istmania.hn
TICKETS_GENERAL_MANAGER_EMAIL=manuel.munguia@istmania.hn

# El modo demo solo puede iniciarlo este usuario y redirige aquí todo el flujo.
TICKETS_DEMO_EMAIL=yovanni.amador@istmania.hn
EMAIL_TLS_REJECT_UNAUTHORIZED=false
