# Servidor
PORT=3045
CORS_ORIGIN=*
REQUEST_BODY_LIMIT=20mb

# SQL Server (la base original usa PACO_ADMIN_S4HANA)
DB_HOST=
DB_PORT=1433
DB_NAME=PACO_ADMIN_S4HANA
DB_USER=
DB_PASSWORD=
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_POOL_MAX=10

# Deben coincidir con JwtIssuerOptions del backend ASP.NET para compatibilidad
JWT_SECRET=
JWT_ISSUER=
JWT_AUDIENCE=
JWT_EXPIRES_IN_SECONDS=7200

# Reemplaza la clave incrustada que usaba ResetPasswordAdmin
ADMIN_RESET_SECRET=

# SMTP usado por GET /api/Paco/Correo
EMAIL_FROM=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_TIMEOUT_MS=10000
EMAIL_TLS_REJECT_UNAUTHORIZED=false
